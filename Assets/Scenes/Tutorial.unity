  m_Script: {fileID: 11500000, guid: 986b2e1bc96763c4eaf9778f9e21ce95, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  uiText: {fileID: 1692592335}
  uiImageArrow: {fileID: 660410330}
  steps:
  - stepText: Welcome to Gapacho! This quick guide will help you master the rules
      of card dueling in just a few minutes. Click anywhere or press Space to continue!
    showArrow: 0
    arrowPosition: {x: 0, y: 0}
    arrowRotationZ: 0
  - stepText: Every match begins with building your hand. Click on your deck to draw
      two random cards.
    showArrow: 1
    arrowPosition: {x: -470, y: -57}
    arrowRotationZ: 114.566
  - stepText: You must choose one of the two cards to add to your hand. The other
      one goes to the discard pile. Collect a total of 4 cards to start the battle.
    showArrow: 0
    arrowPosition: {x: 0, y: 0}
    arrowRotationZ: 0
  - stepText: Cards have Attack and HP. But watch the suit! Spades always deal full
      damage. Diamonds cut all incoming damage in half. Clubs return massive damage
      upon death. Hearts lose attack power as they get damaged!
    showArrow: 1
    arrowPosition: {x: -515, y: 333}
    arrowRotationZ: 324.443
  - stepText: "On your turn, click your card first, then select any enemy card above
      to attack. Attacks are completely unpunished \u2014 the enemy cannot strike
      back during your turn!"
    showArrow: 0
    arrowPosition: {x: 0.61462, y: -0.0089111}
    arrowRotationZ: 0
  - stepText: Destroy all 4 of the bot's cards to win the game! Victory rewards you
      with ranking points (PTS) for each of your SURVIVING cards. Good luck, player!
    showArrow: 1
    arrowPosition: {x: 0.61462, y: -0.0089111}
    arrowRotationZ: 0
